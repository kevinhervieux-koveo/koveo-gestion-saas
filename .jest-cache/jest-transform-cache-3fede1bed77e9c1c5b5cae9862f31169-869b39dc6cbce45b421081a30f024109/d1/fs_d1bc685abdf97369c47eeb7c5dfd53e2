// Mock fs functions
const mockReadFile = (path, options, callback) => {
  if (typeof options === 'function') {
    callback = options;
    options = 'utf8';
  }
  
  const file = mockFileSystem.get(path);
  const content = file ? file.content : 'Mock file content';
  
  if (callback) {
    setImmediate(() => callback(null, content));
  } else {
    return Promise.resolve(content);
  }
};

const mockWriteFile = (path, data, options, callback) => {
  if (typeof options === 'function') {
    callback = options;
    options = 'utf8';
  }
  
  mockFileSystem.set(path, {
    content: data,
    stats: createMockStats(true, false)
  });
  
  if (callback) {
    setImmediate(() => callback(null));
  } else {
    return Promise.resolve();
  }
};

const mockStat = (path, callback) => {
  const file = mockFileSystem.get(path);
  const stats = file ? file.stats : createMockStats(true, false);
  
  if (callback) {
    setImmediate(() => callback(null, stats));
  } else {
    return Promise.resolve(stats);
  }
};

const mockAccess = (path, mode, callback) => {
  if (typeof mode === 'function') {
    callback = mode;
    mode = 0;
  }
  
  const exists = mockFileSystem.has(path);
  const error = exists ? null : new Error('ENOENT: no such file or directory');
  
  if (callback) {
    setImmediate(() => callback(error));
  } else {
    return exists ? Promise.resolve() : Promise.reject(error);
  }
};

const mockMkdir = (path, options, callback) => {
  if (typeof options === 'function') {
    callback = options;
    options = {};
  }
  
  mockFileSystem.set(path, {
    content: '',
    stats: createMockStats(false, true)
  });
  
  if (callback) {
    setImmediate(() => callback(null));
  } else {
    return Promise.resolve();
  }
};

const mockReaddir = (path, options, callback) => {
  if (typeof options === 'function') {
    callback = options;
    options = {};
  }
  
  const files = ['mock-file.txt', 'mock-dir'];
  
  if (callback) {
    setImmediate(() => callback(null, files));
  } else {
    return Promise.resolve(files);
  }
};

