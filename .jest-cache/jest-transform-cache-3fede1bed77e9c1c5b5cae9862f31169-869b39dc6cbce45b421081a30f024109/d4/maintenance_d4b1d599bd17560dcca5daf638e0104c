                        estimatedCost: null,
                        suggestedDate: new Date(currentDate.getTime() + 60 * 24 * 60 * 60 * 1000) // 60 days from now
                    });
                }
                // Check inspection schedules
                if (element.nextEvaluationDate && new Date(element.nextEvaluationDate) <= currentDate) {
