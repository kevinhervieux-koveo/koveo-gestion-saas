     * POST /api/maintenance/projects/:id/reopen-step - Reopen/revert project to previous workflow step
     */
    app.post('/api/maintenance/projects/:id/reopen-step', auth_1.requireAuth, async (req, res) => {
        try {
            const user = req.user;
            if (!user) {
                return res.status(401).json({ error: 'Authentication required' });
            }
            const id = req.params.id;
            if (!id) {
                return res.status(400).json({ error: 'Project ID is required' });
            }
            // Validate current status from request body
            const validation = zod_1.z.object({
                currentStatus: zod_1.z.enum(['submission', 'pre_work', 'in_progress', 'post_work', 'completed']), // Added completed to allow reopening from complete
            }).safeParse(req.body);
            if (!validation.success) {
                return res.status(400).json({
                    error: 'Validation failed',
                    details: validation.error.issues
                });
            }
            // Get project and check access
            const project = await db_1.db
                .select({
                id: maintenance_1.maintenanceProjects.id,
                buildingId: maintenance_1.maintenanceProjects.buildingId,
                status: maintenance_1.maintenanceProjects.status,
                skipSubmission: maintenance_1.maintenanceProjects.skipSubmission,
                skipPreWork: maintenance_1.maintenanceProjects.skipPreWork,
                skipInProgress: maintenance_1.maintenanceProjects.skipInProgress,
                skipPostWork: maintenance_1.maintenanceProjects.skipPostWork,
            })
                .from(maintenance_1.maintenanceProjects)
                .where((0, drizzle_orm_1.eq)(maintenance_1.maintenanceProjects.id, id))
                .limit(1);
            if (project.length === 0) {
                return res.status(404).json({ error: 'Project not found' });
            }
            const hasAccess = await checkBuildingAccess(user.id, project[0].buildingId, user.role);
            if (!hasAccess) {
                return res.status(403).json({ error: 'No access to this project' });
            }
            const currentStatus = validation.data.currentStatus;
            // Verify current status matches project status
            if (project[0].status !== currentStatus) {
                return res.status(400).json({ error: 'Current status does not match project status' });
            }
            // Determine previous status based on current status and skip flags
            let previousStatus;
            switch (currentStatus) {
                case 'submission':
                    previousStatus = 'planned';
                    break;
                case 'pre_work':
                    previousStatus = project[0].skipSubmission ? 'planned' : 'submission';
                    break;
                case 'in_progress':
                    if (project[0].skipPreWork) {
                        previousStatus = project[0].skipSubmission ? 'planned' : 'submission';
                    }
                    else {
                        previousStatus = 'pre_work';
                    }
                    break;
                case 'post_work':
                    if (project[0].skipInProgress) {
                        if (project[0].skipPreWork) {
                            previousStatus = project[0].skipSubmission ? 'planned' : 'submission';
                        }
                        else {
                            previousStatus = 'pre_work';
                        }
                    }
                    else {
                        previousStatus = 'in_progress';
                    }
                    break;
                case 'completed':
                    // Reopen from completed back to post_work (unless post_work was skipped)
                    if (project[0].skipPostWork) {
                        if (project[0].skipInProgress) {
                            if (project[0].skipPreWork) {
                                previousStatus = project[0].skipSubmission ? 'planned' : 'submission';
                            }
                            else {
                                previousStatus = 'pre_work';
                            }
                        }
                        else {
                            previousStatus = 'in_progress';
                        }
                    }
                    else {
                        previousStatus = 'post_work';
                    }
                    break;
                default:
                    return res.status(400).json({ error: 'Invalid status for reopening' });
            }
            // Update project status to previous step
            const updatedProject = await db_1.db
                .update(maintenance_1.maintenanceProjects)
                .set({
                status: previousStatus,
                updatedAt: new Date(),
                // Clear future timestamps when reverting
                ...(currentStatus === 'submission' && { submissionDate: null }),
                ...(currentStatus === 'pre_work' && { preWorkStartDate: null }),
                ...(currentStatus === 'in_progress' && { actualStartDate: null }),
                ...(currentStatus === 'post_work' && { workEndDate: null }),
            })
                .where((0, drizzle_orm_1.eq)(maintenance_1.maintenanceProjects.id, id))
                .returning();
            res.json({
                success: true,
                project: updatedProject[0],
                previousStatus: currentStatus,
                newStatus: previousStatus,
                message: `Project has been reopened to ${previousStatus} step`
            });
        }
        catch (error) {
            console.error('Error reopening project step:', error);
            res.status(500).json({
                error: 'Internal server error',
                message: 'Failed to reopen project step',
            });
        }
    });
