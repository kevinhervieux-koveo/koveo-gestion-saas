#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit validation checks..."

# Run auto-fix for linting issues
echo "🧹 Running lint fixes..."
npm run lint:fix || true

# Check formatting
echo "📋 Checking code formatting..."
npm run format:check || true

# Route security manifest drift check
# Runs only when files under server/ are staged. Blocks commits that
# introduce or modify routes without regenerating server/route-manifest.json.
STAGED_SERVER_FILES=$(git diff --cached --name-only --diff-filter=ACMRD | grep -E '^server/' || true)
if [ -n "$STAGED_SERVER_FILES" ]; then
    echo "🛡️  Checking route security manifest..."
    if ! npx tsx scripts/generate-route-manifest.ts --check; then
        echo ""
        echo "❌ Route manifest is out of date or missing."
        echo "   Run the following, then stage and commit the updated manifest:"
        echo "     npx tsx scripts/generate-route-manifest.ts"
        echo "     git add server/route-manifest.json"
        exit 1
    fi
fi

# Schema-vs-migrations drift check
# Runs only when files under shared/schemas/ or migrations/ are staged.
# Blocks commits that change the Drizzle schema without a matching numbered
# migration (or vice versa), which is the class of issue migration 0009 fixed.
STAGED_SCHEMA_FILES=$(git diff --cached --name-only --diff-filter=ACMRD | grep -E '^(shared/schema(s/.+)?\.ts$|migrations/[0-9]{4}_.+\.sql$)' || true)
if [ -n "$STAGED_SCHEMA_FILES" ]; then
    echo "🛡️  Checking shared/schema.ts vs migrations/ for drift..."
    if ! npx tsx scripts/check-migration-coverage.ts; then
        echo ""
        echo "❌ Schema drift detected between shared/schema.ts and migrations/."
        echo "   Add a numbered migration in migrations/ that brings the deployed"
        echo "   schema in line with shared/schema.ts, then re-stage and commit."
        echo "   See docs/migrations.md for the supported workflow."
        exit 1
    fi
fi

echo "✅ All pre-commit checks passed! Proceeding with commit..."
