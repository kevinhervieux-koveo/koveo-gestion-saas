#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit validation checks..."

# Run auto-fix for linting issues
echo "🧹 Running lint fixes..."
npm run lint:fix || true

# Check formatting
echo "📋 Checking code formatting..."
npm run format:check || true

# Route security manifest drift check
# Runs only when files under server/ are staged. Blocks commits that
# introduce or modify routes without regenerating server/route-manifest.json.
STAGED_SERVER_FILES=$(git diff --cached --name-only --diff-filter=ACMRD | grep -E '^server/' || true)
if [ -n "$STAGED_SERVER_FILES" ]; then
    echo "🛡️  Checking route security manifest..."
    if ! npx tsx scripts/generate-route-manifest.ts --check; then
        echo ""
        echo "❌ Route manifest is out of date or missing."
        echo "   Run the following, then stage and commit the updated manifest:"
        echo "     npx tsx scripts/generate-route-manifest.ts"
        echo "     git add server/route-manifest.json"
        exit 1
    fi
fi

echo "✅ All pre-commit checks passed! Proceeding with commit..."
