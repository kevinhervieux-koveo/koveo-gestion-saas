modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["google-cloud-sdk", "yakut", "jq", "dig"]

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "bash scripts/run-unit-tests.sh full && npm run build && IS_DEPLOY_BUILD=true NODE_ENV=production npm run migrate"]
run = ["npm", "run", "start"]

[[deployment.rewrites]]
from = "/*"
to = "/index.html"

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build verification"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Fast unit tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Full unit tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Suppression lint check"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Type check"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "org-scope-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "org-scope-hoc-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "org-scope-all-tests"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Build verification"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/build-check.sh"

[[workflows.workflow]]
name = "Fast unit tests"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-unit-tests.sh affected"

[[workflows.workflow]]
name = "Full unit tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-unit-tests.sh full"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Suppression lint check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/check-ts-suppressions.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Type check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/type-check.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "org-scope-test"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "TEST_TYPE=unit node_modules/.bin/jest tests/unit/org-scope-residences-and-building-pages.test.tsx --no-coverage --forceExit --testTimeout=15000"

[[workflows.workflow]]
name = "org-scope-hoc-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "TEST_TYPE=unit node_modules/.bin/jest tests/unit/org-scope-hoc-buildings-fetch.test.tsx --no-coverage --forceExit --testTimeout=15000"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "org-scope-all-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "TEST_TYPE=unit node_modules/.bin/jest tests/unit/org-scope-residences-and-building-pages.test.tsx tests/unit/org-scope-hoc-buildings-fetch.test.tsx --no-coverage --forceExit --testTimeout=15000"

[workflows.workflow.metadata]
isValidation = true

[agent]
integrations = ["github:1.0.0"]

[objectStorage]
defaultBucketID = "replit-objstore-080489df-69c3-487c-9caa-3cc4342ecfd3"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 300000

[userenv]

[userenv.shared]
MCP_OAUTH_ISSUER = "https://koveo-gestion.com"

[userenv.production]
ENABLE_MCP_SERVER = "true"
ONBOARDING_ENABLED = "true"
VITE_ONBOARDING_ENABLED = "true"

[userenv.development]
MCP_ASSUME_USER = "1"
